# Astrologia de Luz — environment variables
# Copy to .env.local for local dev. NEVER commit .env.local (gitignored).
# Production values live ONLY in Vercel Project Settings → Environment Variables.
#
# All vars are validated at first getEnv() call (lazy, per G_C-25). Errors are
# Spanish-headed (Variables de entorno faltantes o inválidas:) per AC-2.6.2.

# ─── Turso (libSQL/SQLite database) ──────────────────────────────────────────
# Get both from https://turso.tech after creating a project (free tier).
# URL shape: libsql://<db-name>-<org>.turso.io
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJ...

# ─── Auth.js v5 (NextAuth) ───────────────────────────────────────────────────
# AUTH_SECRET — generate locally: openssl rand -hex 32
# Must be >= 32 chars. Rotate this to force-logout all sessions.
AUTH_SECRET=replace-with-32-plus-char-random-hex

# AUTH_URL — absolute origin of the deployed site (no trailing slash).
# Used for magic-link callbacks. MUST match the Vercel production URL.
AUTH_URL=https://astrologiadeluz.com

# ─── Resend (transactional email transport) ──────────────────────────────────
# Get from https://resend.com/api-keys after verifying your sending domain.
# Key prefix MUST be "re_".
AUTH_RESEND_KEY=re_your_api_key_here

# RESEND_FROM — display name + verified address. Format: "Name <addr@domain>".
# The @ domain MUST be the verified domain in Resend (DKIM/SPF/return-path set).
RESEND_FROM=Astrologia de Luz <no-reply@astrologiadeluz.com>

# ─── Admin allowlist (comma-separated emails) ────────────────────────────────
# First entry = canonical brand-owner email (matches seeded teachers row).
# Auth.js v5 disableSignUp gates magic-link auth to entries on this list.
# Lower-cased + trimmed at lookup time (see brandOwnerEmail helper).
ADMIN_EMAILS=augusto@astrologiadeluz.com

# ─── Telegram bot (visitor request notifications) ────────────────────────────
# Create via @BotFather on Telegram. Format: <numeric>:<token>.
TELEGRAM_BOT_TOKEN=0000000000:replace-with-bot-token

# Bot username WITHOUT the leading @. Used for /start deep-link URLs.
TELEGRAM_BOT_USERNAME=AstrologiaDeLuzBot

# Webhook secret — generate locally: openssl rand -hex 32
# Sent as X-Telegram-Bot-Api-Secret-Token header on every webhook call.
# Set on Telegram side via setWebhook?secret_token=<this-value>.
TELEGRAM_WEBHOOK_SECRET=replace-with-32-plus-char-random-hex
