# .env.local.example — placeholders. Copy to .env.local (gitignored) for desarrollo local.
# Valores reales viven en Vercel para producción. Cualquier ausencia o formato inválido
# rompe el boot con un mensaje en castellano (ver lib/env.ts). Spec: AC-2.6.1 + AC-3.9.

# --- Datos (Turso libSQL) -----------------------------------------------------
TURSO_DATABASE_URL="libsql://astrologiadeluz-<org>.turso.io"
TURSO_AUTH_TOKEN="<JWT-de-la-consola-Turso>"

# --- Auth (Auth.js v5 + Resend provider) --------------------------------------
# AUTH_SECRET: generar con `npx auth secret` (32+ bytes base64).
AUTH_SECRET="reemplazar-por-32-o-mas-bytes-aleatorios-base64"
AUTH_URL="http://localhost:3000"
AUTH_RESEND_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Astrologia de Luz <notificaciones@astrologiadeluz.com>"
# ADMIN_EMAILS: lista de acceso del panel. Coma-separada. El primer correo es el dueño/marca.
ADMIN_EMAILS="gabi@example.com,augusto@example.com"

# --- Notificaciones (Telegram bot) --------------------------------------------
# TELEGRAM_BOT_TOKEN: viene de @BotFather. Formato <numérico>:<token>.
TELEGRAM_BOT_TOKEN="0000000000:reemplazar-por-token-de-BotFather"
TELEGRAM_BOT_USERNAME="AstrologiaDeLuzBot"
# TELEGRAM_WEBHOOK_SECRET: generar con `openssl rand -hex 32`.
TELEGRAM_WEBHOOK_SECRET="reemplazar-por-32-o-mas-bytes-aleatorios-hex"
